# Copy this file to /etc/owui-mcp-spawner.env and set a strong password.
# Restrict permissions: sudo chmod 600 /etc/owui-mcp-spawner.env
#
# Option A — plain-text password (hashed with SHA-256 at startup):
MCP_MANAGER_PASSWORD=change-me

# Option B — pre-hashed SHA-256 digest (takes precedence over the above):
# MCP_MANAGER_PASSWORD_HASH=your-sha256-hex-digest-here
