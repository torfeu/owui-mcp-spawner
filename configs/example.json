{
  "id": "my_tool",
  "name": "My Tool",
  "description": "Example MCP server configuration",
  "locked": false,
  "server": {
    "host": "127.0.0.1",
    "port": 8101,
    "endpoint": "/mcp"
  },
  "venv": "default",
  "install": {
    "dependencies": [
      "requests>=2.28.0"
    ],
    "upgrade": false
  },
  "tool_source": {
    "type": "openwebui_json",
    "path": "./tools/my_tool.json"
  },
  "values": {
    "api_url": "https://api.example.com",
    "api_key": ""
  },
  "lifecycle": {
    "auto_start": false,
    "restart_on_change": true
  }
}
